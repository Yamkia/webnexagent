<odoo>
  <record id="view_create_module_wizard_form" model="ir.ui.view">
    <field name="name">create.module.wizard.form</field>
    <field name="model">create.module.wizard</field>
    <field name="arch" type="xml">
      <form string="Create Module">
        <group>
          <field name="name"/>
          <field name="module_name"/>
          <field name="author"/>
          <field name="license"/>
          <field name="short_description"/>
        </group>
        <footer>
          <button string="Create" type="object" name="action_create_module" class="btn-primary"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
