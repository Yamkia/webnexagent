<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_white_label_brand_tree" model="ir.ui.view">
    <field name="name">white.label.tree</field>
    <field name="model">white.label</field>
    <field name="arch" type="xml">
      <tree string="Brands">
        <field name="name"/>
        <field name="code"/>
        <field name="primary_color" widget="color"/>
        <field name="secondary_color" widget="color"/>
        <field name="is_active"/>
      </tree>
    </field>
  </record>

  <record id="view_white_label_brand_form" model="ir.ui.view">
    <field name="name">white.label.form</field>
    <field name="model">white.label</field>
    <field name="arch" type="xml">
      <form string="Brand">
        <sheet>
          <div class="oe_title">
            <label for="name" class="oe_edit_only"/>
            <h1><field name="name" placeholder="Brand Name"/></h1>
          </div>
          <group>
            <group>
              <field name="code"/>
              <field name="is_active"/>
            </group>
            <group>
              <field name="primary_color" widget="color"/>
              <field name="secondary_color" widget="color"/>
            </group>
          </group>
          <group string="Assets">
            <field name="logo_svg" placeholder="/path/to/logo.svg"/>
            <field name="favicon" widget="image"/>
          </group>
          <notebook>
            <page string="Websites">
              <field name="website_ids">
                <tree>
                  <field name="name"/>
                  <field name="domain"/>
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_white_label_brand" model="ir.actions.act_window">
    <field name="name">Brands</field>
    <field name="res_model">white.label</field>
    <field name="view_mode">tree,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Create your first brand
      </p>
      <p>
        Define brand profiles to white-label your Odoo environment.
      </p>
    </field>
  </record>

  <menuitem id="menu_white_label_brand_root"
            name="Brand Management"
            sequence="100"/>

  <menuitem id="menu_white_label_brand"
            name="Brands"
            parent="menu_white_label_brand_root"
            action="action_white_label_brand"
            sequence="10"/>
</odoo>
